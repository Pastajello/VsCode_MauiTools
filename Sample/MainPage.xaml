<ContentPage
    x:Class="Sample.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Sample"
    x:Name="RootPage"
    Title="Advanced XAML Sample">

    <ContentPage.Resources>
        <ResourceDictionary>

            <!--  Static + Dynamic resources  -->
            <Color x:Key="PrimaryColor">#512BD4</Color>
            <Color x:Key="SecondaryColor">#FF4081</Color>

            <Style x:Key="TitleLabelStyle" TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource PrimaryColor}" />
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>

        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>

        <VerticalStackLayout Padding="20" Spacing="16">
            <Grid RowDefinitions="50, 50">
                <Label Grid.Row="1" Text="{Binding User.Details.Description}" />
            </Grid>
            <!--  x:DataType (compiled binding)  -->
            <VerticalStackLayout x:DataType="local:MainViewModel">

                <Label Style="{StaticResource TitleLabelStyle}" Text="Advanced MAUI Toolkit Demo" />

                <!--  Binding with nested path  -->
                <Label Text="{Binding User.Details.Description}" />

                <!--  Binding with Source  -->
                <Label Text="{Binding Source={x:Reference RootPage}, Path=Title}" />

                <!--  Entry with binding  -->
                <Entry Placeholder="Enter name" Text="{Binding User.Title}" />

                <!--  Button with command  -->
                <Button Command="{Binding SubmitCommand}" Text="Execute" />

                <!--  Dynamic resource usage  -->
                <Label Text="Dynamic color" TextColor="{DynamicResource SecondaryColor}" />

                <!--  Collection with x:DataType  -->
                <CollectionView ItemsSource="{Binding Items}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="local:ItemModel">
                            <Border Margin="5" Padding="10">
                                <VerticalStackLayout>
                                    <Label Text="{Binding Source={RelativeSource Mode=FindAncestor, AncestorType={x:Type local:MainPage}}, Path=Title, x:DataType=local:MainPage}" />
                                    <Label FontAttributes="Bold" Text="{Binding Title}" />

                                    <!--  Nested binding  -->
                                    <Label FontSize="12" Text="{Binding Details.Description}" />

                                    <!--  RelativeSource binding  -->
                                    <Label FontSize="10" Text="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=Title}" />

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!--  VisualStateManager  -->
                <Button Text="State Button">
                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup Name="Oh">

                            <VisualState Name="My" />

                            <VisualState Name="God">
                                <VisualState.Setters>
                                    <Setter Property="BackgroundColor" Value="LightGray" />
                                </VisualState.Setters>
                            </VisualState>

                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>
                </Button>

                <!--  Trigger with binding  -->
                <Entry Placeholder="Trigger test">
                    <Entry.Triggers>
                        <DataTrigger
                            Binding="{Binding User.Title}"
                            TargetType="Entry"
                            Value="">
                            <Setter Property="BackgroundColor" Value="LightPink" />
                        </DataTrigger>
                    </Entry.Triggers>
                </Entry>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
